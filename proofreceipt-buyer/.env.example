# ProofReceipt buyer environment variables
# Copy this file and fill in the secret values before running the buyer.
# DO NOT commit a file containing real keys.

# URL of the ProofReceipt audit server
SERVER_URL=http://127.0.0.1:8081

# Deployed RISC Zero verifier contract on Stellar testnet (unchanged across M0–M3)
VERIFIER_ID=CCR6QRJJBEFKUDE4YXQ2L6VII6M6C57ENXXJ5A4HQWOO6PYKRP4KS4IU

# M3 guest image_id — must match the server's configured image_id exactly
AGREED_IMAGE_ID=ffc622e891883f70242e3dfea5ccb2b68b73136b30aed868f8f48242cc9eeddd

# Stellar keypair for the buyer account (e.g. the e2e-buyer identity).
# Source from the Stellar CLI so the raw seed never appears in shell history.
CLIENT_PRIVATE_KEY="$(stellar keys show e2e-buyer)"
CLIENT_PUBLIC_KEY="$(stellar keys address e2e-buyer)"
