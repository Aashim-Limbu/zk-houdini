# --- denomination map (pool denom id -> zUSDC amount @ 7 decimals) ---
# DECISION (confirm when wiring the e2e prover): denom id = USDC *value* {1,10,100}.
# EVM tree is keyed by denomIndex {0,1,2}; relayer must map index->value before
# update_root/withdraw, and the circuit 'denomination' public input must equal the value.
DENOM_1=10000000
DENOM_10=100000000
DENOM_100=1000000000
